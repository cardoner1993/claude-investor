# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# FRED API key — free, 1-minute signup:
# https://fred.stlouisfed.org/docs/api/api_key.html
# Without this, the Fed leg of the liquidity snapshot shows "n/a".
FRED_API_KEY=

# Logging verbosity for the app (DEBUG | INFO | WARNING | ERROR)
# GPT_INVESTOR_LOG_LEVEL=INFO

# Disk-cache TTL for the liquidity snapshot, in seconds (default: 21600 = 6h)
# LIQUIDITY_TTL_SECONDS=21600

# Max tickers analyzed per run (default: 4)
# MAX_TICKERS_TO_ANALYZE=4
